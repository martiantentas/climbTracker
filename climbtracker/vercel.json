{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/stripe-webhook.ts": {
      "runtime": "@vercel/node@5.7.12",
      "maxDuration": 30
    },
    "api/verify-payment.ts": {
      "runtime": "@vercel/node@5.7.12",
      "maxDuration": 15
    },
    "api/create-checkout-session.ts": {
      "runtime": "@vercel/node@5.7.12",
      "maxDuration": 15
    },
    "api/contact.ts": {
      "runtime": "@vercel/node@5.7.12",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
